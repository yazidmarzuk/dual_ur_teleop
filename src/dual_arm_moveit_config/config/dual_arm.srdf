  <disable_collisions link1="right_base_link_inertia"  link2="left_wrist_2_link"    reason="Never"/>
  <disable_collisions link1="right_base_link_inertia"  link2="left_wrist_3_link"    reason="Never"/>
  <disable_collisions link1="right_base_link_inertia"  link2="left_gripper_base"    reason="Never"/>
  <disable_collisions link1="right_base_link_inertia"  link2="left_left_finger"     reason="Never"/>
  <disable_collisions link1="right_base_link_inertia"  link2="left_right_finger"    reason="Never"/>

</robot>

